import json
from pathlib import Path

val = json.load(open(r'C:\Users\Alvin\surgical_cv_project\data\MATIS\endovis_2017\annotations\Fold0\val.json'))
cats = {c['id']: c['name'] for c in val['categories']}
from collections import Counter
counts = Counter()
for ann in val['annotations']:
    counts[cats[ann['category_id']]] += 1
for name, c in sorted(counts.items(), key=lambda x: -x[1]):
    print(f'  {name:<35} {c}')